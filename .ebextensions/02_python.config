option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: wsgi:application  # Point to wsgi.py and the application object

  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: "/var/app/current:$PYTHONPATH"

packages:
  yum:
    python3-devel: []

container_commands:
  01_upgrade_pip:
    command: "python3 -m pip install --upgrade pip"
  02_install_requirements:
    command: "python3 -m pip install -r requirements.txt"
  03_create_log_directory:
    command: "mkdir -p /var/log/encryptgate"
  04_set_permissions:
    command: |
      chmod -R 777 /var/log/encryptgate
      chown -R ec2-user:ec2-user /var/log/encryptgate  # Ensure correct ownership
