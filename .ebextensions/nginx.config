files:
  "/etc/nginx/conf.d/proxy.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Define upstream server
      upstream flaskapp {
        server 127.0.0.1:8080;
        keepalive 256;
      }
      
      # Increase timeouts
      proxy_connect_timeout 300s;
      proxy_read_timeout 300s;
      proxy_send_timeout 300s;
      send_timeout 300s;
      keepalive_timeout 300s;
      
      server {
          listen 80;
          server_name _;
          
          # Handle preflight OPTIONS requests
          if ($request_method = 'OPTIONS') {
              add_header 'Access-Control-Allow-Origin' 'https://console-encryptgate.net' always;
              add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS, PUT, DELETE' always;
              add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization,Accept,Origin' always;
              add_header 'Access-Control-Allow-Credentials' 'true' always;
              add_header 'Access-Control-Max-Age' '1728000';
              add_header 'Content-Type' 'text/plain; charset=utf-8';
              add_header 'Content-Length' '0';
              return 204;
          }
          
          # Health check endpoint for AWS load balancer
          location /health {
              proxy_pass http://flaskapp/health;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              access_log off;
          }

          # Root API endpoint
          location /api {
              proxy_pass http://flaskapp/api;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              
              # Add CORS headers for non-OPTIONS requests
              add_header 'Access-Control-Allow-Origin' 'https://console-encryptgate.net' always;
              add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS, PUT, DELETE' always;
              add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization,Accept,Origin' always;
              add_header 'Access-Control-Allow-Credentials' 'true' always;
          }
          
          # Auth Routes
          location /api/auth/ {
              proxy_pass http://flaskapp/api/auth/;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              
              # Add CORS headers for non-OPTIONS requests
              add_header 'Access-Control-Allow-Origin' 'https://console-encryptgate.net' always;
              add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS, PUT, DELETE' always;
              add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization,Accept,Origin' always;
              add_header 'Access-Control-Allow-Credentials' 'true' always;
          }
          
          # User Auth Routes (login, confirm-signup, verify-mfa)
          location /api/user/ {
              proxy_pass http://flaskapp/api/user/;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              
              # Add CORS headers for non-OPTIONS requests
              add_header 'Access-Control-Allow-Origin' 'https://console-encryptgate.net' always;
              add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS, PUT, DELETE' always;
              add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization,Accept,Origin' always;
              add_header 'Access-Control-Allow-Credentials' 'true' always;
          }
          
          # Direct authenticate endpoint
          location /authenticate {
              proxy_pass http://flaskapp/authenticate;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              
              # Add CORS headers for non-OPTIONS requests
              add_header 'Access-Control-Allow-Origin' 'https://console-encryptgate.net' always;
              add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS, PUT, DELETE' always;
              add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization,Accept,Origin' always;
              add_header 'Access-Control-Allow-Credentials' 'true' always;
          }
          
          # Forward all other requests to Flask running on port 8080
          location / {
              proxy_pass http://flaskapp;
              proxy_set_header Host $host;
              proxy_set_header X-Real-IP $remote_addr;
              proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
              proxy_set_header X-Forwarded-Proto $scheme;
              
              # Add CORS headers for non-OPTIONS requests
              add_header 'Access-Control-Allow-Origin' 'https://console-encryptgate.net' always;
              add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS, PUT, DELETE' always;
              add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization,Accept,Origin' always;
              add_header 'Access-Control-Allow-Credentials' 'true' always;
          }
      }

container_commands:
  01_nginx_config_test:
    command: "nginx -t || echo 'Nginx config test failed but continuing'"
  02_reload_nginx:
    command: "service nginx reload || service nginx restart"
  03_create_markers:
    command: "mkdir -p /tmp/nginx-initialized && touch /tmp/nginx-initialized/marker"
  04_clear_nginx_cache:
    command: "rm -rf /var/cache/nginx/* || true"